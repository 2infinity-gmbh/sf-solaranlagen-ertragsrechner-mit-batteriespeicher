---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.id },
    props: article,
  }));
}

const article = Astro.props;
const { Content } = await render(article);
---

<Layout title={article.data.title} description={article.data.description ?? ''}>
  <article class="prose prose-lg max-w-none">
    <h1>{article.data.title}</h1>
    <time
      datetime={article.data.pubDate.toISOString()}
      class="block text-sm text-gray-500 -mt-4 mb-8"
    >
      {article.data.pubDate.toLocaleDateString('de-DE', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      })}
    </time>
    <Content />
  </article>

  <div class="mt-12 pt-6 border-t border-gray-200">
    <a href="/" class="text-blue-600 hover:text-blue-800">&larr; Zurueck zur Uebersicht</a>
  </div>
</Layout>
